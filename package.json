{
  "name": "@citrineos/workspace",
  "version": "1.9.1",
  "type": "module",
  "private": false,
  "scripts": {
    "install-all": "npm i --verbose",
    "copy-assets": "npm run copy-assets --prefix ./Server",
    "build": "tsc --build --verbose && tsc-alias -p core/tsconfig.json && tsc-alias -p base/tsconfig.json",
    "postbuild": "npm run copy-assets",
    "clear-cache": "npm cache clean --force",
    "remove-dependencies": "rm -rf package-lock.json **/package-lock.json **/**/package-lock.json node_modules **/node_modules **/**/node_modules",
    "fresh": "npm run clean && npm run remove-dependencies && npm run clear-cache",
    "clean-tsbuildinfo": "find . -name tsconfig.tsbuildinfo -not -path '*/node_modules/*' -exec rm -f {} +",
    "clean-dist": "find . -type d -name dist -not -path '*/node_modules/*' -exec rm -rf {} +",
    "clean": "npm run clean-dist && npm run clean-tsbuildinfo",
    "start": "npm run start --prefix ./Server",
    "start-docker": "npm run start-docker --prefix ./Server",
    "start-docker-cloud": "npm run start-docker-cloud --prefix ./Server",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "prettier": "prettier --write .",
    "fi": "npm run fresh && npm run install-all",
    "sync-db": "ts-node ./db.sync.ts",
    "force-sync-db": "ts-node ./db.force-sync.ts",
    "test": "vitest run --exclude='**/*.e2e.test.ts'",
    "test:e2e": "npm run build && vitest run --include='**/test/e2e/*.e2e.test.ts'",
    "coverage": "vitest run --coverage",
    "prepare": "husky",
    "migrate": "npx sequelize-cli db:migrate --debug && echo migration completed successfully"
  },
  "lint-staged": {
    "**/*.{js,ts,jsx,tsx,json,md}": "prettier --write"
  },
  "workspaces": [
    "base",
    "core",
    "Server"
  ],
  "engines": {
    "node": ">=24.4.1"
  },
  "devDependencies": {
    "@types/jsrsasign": "^10.5.15",
    "@types/node": "^25.3.3",
    "madge": "^8.0.0",
    "openapi-types": "^12.1.3",
    "@types/pg": "8.20.0",
    "tsc-alias": "^1.8.16",
    "testcontainers": "11.13.0",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@google-cloud/storage": "^7.19.0",
    "@peculiar/webcrypto": "^1.5.0",
    "acme-client": "^5.4.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "asn1js": "^3.0.7",
    "bufferutil": "^4.1.0",
    "jsrsasign": "^11.1.1",
    "jwks-rsa": "^4.0.1",
    "pkijs": "^3.3.3",
    "pvutils": "^1.1.5",
    "redis": "^4.7.1",
    "sequelize-cli": "^6.6.2",
    "sequelize-typescript": "^2.1.6",
    "tsconfig-paths": "^4.2.0",
    "utf-8-validate": "^6.0.6"
  }
}
