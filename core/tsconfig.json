{
  "extends": "../tsconfig.build.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@dal/*": ["./src/dal/*"],
      "@modules/*": ["./src/modules/*"],
      "@util/*": ["./src/util/*"]
    }
  },
  "include": ["**/*", "**/*.json"],
  "exclude": ["**/dist/**", "**/node_modules/**", "**/vitest.config.ts", "**/test/**"],
  "references": [
    {
      "path": "../base"
    }
  ]
}
