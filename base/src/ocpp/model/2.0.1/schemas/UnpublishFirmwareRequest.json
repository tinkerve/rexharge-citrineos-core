{
  "$id": "UnpublishFirmwareRequest",
  "comment": "OCPP 2.0.1 FINAL",
  "definitions": {
    "CustomDataType": {
      "description": "Represents OCPP CustomData. Allows vendor-specific extension properties.",
      "javaType": "CustomData",
      "type": "object",
      "properties": {
        "vendorId": {
          "type": "string",
          "maxLength": 255
        }
      },
      "required": ["vendorId"]
    }
  },
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "customData": {
      "$ref": "#/definitions/CustomDataType"
    },
    "checksum": {
      "description": "The MD5 checksum over the entire firmware file as a hexadecimal string of length 32. \r\n",
      "type": "string",
      "maxLength": 32
    }
  },
  "required": ["checksum"]
}
