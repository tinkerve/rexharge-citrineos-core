{
  "exclude": ["./node_modules", "**/__tests__/*", "./dist", "./**/dist", "./**/**/dist"],
  "include": [
    "base/**/*.ts",
    "base/**/*.json",
    "core/**/*.ts",
    "core/**/*.json",
    "Server/**/*.ts",
    "Server/**/*.json",
    "./db.sync.ts",
    "./db.force-sync.ts",
    "vitest.config.ts",
    "migrations/**/*.ts",
    "seeders/**/*.ts"
  ],
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "verbatimModuleSyntax": true
  }
}
