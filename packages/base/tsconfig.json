{
  "extends": "../../tsconfig.build.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@ocpp/*": ["./src/ocpp/*"],
      "@config/*": ["./src/config/*"],
      "@interfaces/*": ["./src/interfaces/*"],
      "@base-util/*": ["./src/util/*"]
    }
  },
  "include": ["**/*", "**/*.json"],
  "exclude": ["**/dist/**", "**/node_modules/**", "**/vitest.config.ts", "**/test/**"]
}
